# BU Alumni Portal - Backend Configuration
# IMPORTANT: Update these values before starting the server

# ── Server Configuration ──────────────────────────────────────────────────────
PORT=5000
BASE_URL=http://localhost:5000

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Generate a strong secret with: python -c "import secrets; print(secrets.token_hex(32))"
# CHANGE THIS BEFORE RUNNING THE SERVER!
JWT_SECRET=CHANGE-THIS-TO-A-STRONG-RANDOM-SECRET-BEFORE-RUNNING

# ── SMTP Email Configuration ──────────────────────────────────────────────────
# For Gmail: Use an App Password (not your regular password)
# 1. Enable 2-Factor Authentication: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and your device
# 4. Copy the 16-character password (no spaces)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password-here
SMTP_FROM_NAME=BU Alumni Portal

# ── Notes ─────────────────────────────────────────────────────────────────────
# - Never commit this file to version control
# - For production, use environment variables instead of this file
# - For other email providers, see BACKEND_SETUP.md
