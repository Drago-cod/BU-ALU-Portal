# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Node.js Server Port (default: 8080)
PORT=8080

# Python Flask Server Port (default: 5000)
FLASK_PORT=5000

# Base URL for API endpoints (use the server you're running)
BASE_URL=http://localhost:5000

# =============================================================================
# SECURITY
# =============================================================================
# JWT Secret Key (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# =============================================================================
# SMTP / EMAIL CONFIGURATION (Gmail example)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=BU Alumni Portal
SMTP_FROM_EMAIL=your-email@gmail.com

# =============================================================================
# MOBILE MONEY (MoMo) CONFIGURATION (Sandbox/Test mode)
# =============================================================================
# MTN MoMo API credentials (for production)
MTN_API_USER=your-mtn-api-user
MTN_API_KEY=your-mtn-api-key
MTN_SUBSCRIPTION_KEY=your-mtn-subscription-key

# Airtel Money API credentials (for production)
AIRTEL_CLIENT_ID=your-airtel-client-id
AIRTEL_CLIENT_SECRET=your-airtel-client-secret

# =============================================================================
# DATABASE
# =============================================================================
# SQLite database path (default: backend/data/bu_alumni.db)
DATABASE_PATH=backend/data/bu_alumni.db

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable email sending (set to false for development)
ENABLE_EMAILS=true

# Enable/disable PDF generation (set to false for development)
ENABLE_PDFS=true

# Environment mode: development, testing, production
ENVIRONMENT=development
